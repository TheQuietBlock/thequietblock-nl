---
interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;

const links = [
  { href: '/', label: 'Home', page: 'home' },
  { href: '/rules', label: 'Rules', page: 'rules' },
  { href: '/faq', label: 'FAQ', page: 'faq' },
  { href: '/community', label: 'Community', page: 'community' },
  { href: '/join', label: 'Join', page: 'join' },
];
---

<nav class="top-nav" aria-label="Primary">
  <div class="container top-nav-inner">
    {links.map(link => (
      <a href={link.href} aria-current={currentPage === link.page ? 'page' : undefined}>
        {link.label}
      </a>
    ))}
  </div>
</nav>
