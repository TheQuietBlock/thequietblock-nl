---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const highlights = [
  { title: 'Staff Team', text: 'Our moderators and admins work behind the scenes to support a safe, welcoming server.' },
  { title: 'Community Spotlight', text: 'Discover player builds, shared achievements, and standout moments from the server.' },
];
---

<BaseLayout title="TheQuietBlock Community" description="Community overview for TheQuietBlock." currentPage="community">
  <Hero slot="hero" eyebrow="Community Node" title="Community Highlights" subtitle="Moderation, builds, and player moments that keep the server healthy and fun." />

  <section class="cards" aria-label="Community highlights">
    {highlights.map(card => (
      <article class="card">
        <h2>{card.title}</h2>
        <p>{card.text}</p>
      </article>
    ))}
  </section>
</BaseLayout>
