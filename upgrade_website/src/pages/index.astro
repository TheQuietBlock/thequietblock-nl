---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PanelChrome from '../components/PanelChrome.astro';
---

<BaseLayout title="TheQuietBlock" description="TheQuietBlock Minecraft community server." currentPage="home">
  <Hero slot="hero" eyebrow="Secure Community Node" title="Welcome to TheQuietBlock" subtitle="A polished Minecraft community focused on smooth gameplay, fair moderation, and a relaxed social vibe.">
    <a class="btn-primary" href="/join" aria-label="Apply for whitelist access">Join Server</a>
    <a class="btn-secondary" href="/rules" aria-label="Read server rules">Rules</a>
    <a class="btn-secondary" href="/faq" aria-label="Read frequently asked questions">FAQ</a>
  </Hero>

  <section id="status" class="status-panel" aria-labelledby="status-title">
    <PanelChrome label="server-status.sh" />
    <h2 id="status-title">Server Status</h2>
    <p id="status-message">Live server status will be shown here soon, including online/offline state and current player count.</p>
    <dl class="status-grid" aria-live="polite">
      <div>
        <dt><span class="status-dot" id="status-dot"></span> State</dt>
        <dd id="server-state">Unknown</dd>
      </div>
      <div>
        <dt>Players</dt>
        <dd id="player-count">-/-</dd>
      </div>
      <div>
        <dt>Version</dt>
        <dd id="server-version">Not available</dd>
      </div>
      <div>
        <dt>MOTD</dt>
        <dd id="server-motd">Not available</dd>
      </div>
    </dl>
    <button id="refresh-status" class="btn-secondary" type="button" aria-label="Refresh server status">Refresh Status</button>
    <p class="whitelist-note">This is a whitelist server. <a href="/join" class="whitelist-link">Apply here</a> to get access.</p>
  </section>

  <script>
    import { initServerStatus, initBootSequence } from '../scripts/status';

    document.addEventListener('astro:page-load', () => {
      initServerStatus();
      initBootSequence();
    });
  </script>
</BaseLayout>
