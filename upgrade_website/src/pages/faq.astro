---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const faqs = [
  { question: 'How do I join the server?', answer: 'Launch Minecraft Java Edition, add <code>mc.thequietblock.nl</code> to your server list, and connect.' },
  { question: 'Is the server beginner-friendly?', answer: 'Yes. New players are welcome, and the community is encouraged to be helpful and respectful.' },
  { question: 'Where can I read all rules?', answer: 'Read the full rule set on the dedicated <a href="/rules">Rules page</a>.' },
  { question: 'Who do I contact for support?', answer: 'Support contact options will be published soon on the website.' },
];
---

<BaseLayout title="TheQuietBlock FAQ" description="Frequently asked questions for TheQuietBlock." currentPage="faq">
  <Hero slot="hero" eyebrow="Support Console" title="Frequently Asked Questions" subtitle="Quick answers for joining, rules, and support." />

  <section class="faq" aria-labelledby="faq-title">
    <h2 id="faq-title">FAQ</h2>

    {faqs.map(faq => (
      <details>
        <summary>{faq.question}</summary>
        <p set:html={faq.answer} />
      </details>
    ))}
  </section>
</BaseLayout>
