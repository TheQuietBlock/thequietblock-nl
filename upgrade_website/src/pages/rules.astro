---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PanelChrome from '../components/PanelChrome.astro';

const rules = [
  { num: '01', title: 'Respect other players.', desc: 'No harassment, no toxic behavior, no real-world drama spillover. Keep chat civil. This is a shared world, not a battleground of egos.' },
  { num: '02', title: 'No griefing or stealing.', desc: 'Do not break, modify, or take anything that isn\u2019t yours without permission. Even \u201Csmall stuff\u201D counts. Trust is the foundation of survival multiplayer.' },
  { num: '03', title: 'PvP by agreement only.', desc: 'Combat is allowed only if both players agree beforehand. No trap bases, no lava ambushes, no surprise kill farms targeting players.' },
  { num: '04', title: 'No cheats, exploits, or unfair mods.', desc: 'No hacked clients, x-ray, duplication glitches, auto-clickers, or abuse of game-breaking bugs. Performance mods like Sodium are fine as long as they don\u2019t give gameplay advantages.' },
  { num: '05', title: 'Build responsibly.', desc: 'No lag machines, excessive entity farms, or redstone clocks that constantly run. If your build tanks TPS, you\u2019ll be asked to optimize it. Survival is hard enough without fighting the server.' },
  { num: '06', title: 'Respect world integrity.', desc: 'No random destruction of terrain just because \u201Cit\u2019s survival.\u201D Don\u2019t leave floating trees, giant creeper craters, or strip-mined wastelands near spawn. Clean up after yourself.' },
  { num: '07', title: 'Claim and space your base.', desc: 'Don\u2019t build too close to others without asking. Mark your base clearly with signs. Spawn area stays clean and welcoming.' },
  { num: '08', title: 'AFK farming limits.', desc: 'Short AFK sessions are fine. 24/7 AFK setups that monopolize mob caps or stress the server are not allowed.' },
  { num: '09', title: 'Admin decisions are final.', desc: 'Admins maintain server stability and fairness. Backups exist, but they are for accidents, not arguments.' },
  { num: '10', title: 'Play survival as intended.', desc: 'No creative access, no spawned items, no special privileges unless explicitly stated. Everyone earns their progress.' },
];
---

<BaseLayout title="TheQuietBlock Rules" description="Server rules for TheQuietBlock." currentPage="rules">
  <Hero slot="hero" eyebrow="Policy Ledger" title="Server Rules" subtitle="Simple, stable rules to protect progression and keep the world fair." />

  <section class="term-window" aria-labelledby="rules-title">
    <PanelChrome label="rules.cfg — read-only" />

    <div class="term-body">
      <div class="term-prompt-line" aria-hidden="true">
        <span class="term-ps1">admin@thequietblock</span><span class="term-sep">:</span><span class="term-cwd">~</span><span class="term-sep">$</span><span class="term-cmd-text"> cat rules.cfg</span>
      </div>

      <div class="term-divider" aria-hidden="true"></div>

      <h2 id="rules-title" class="sr-only">Full Rule Set</h2>

      <ol class="term-rules" aria-label="Server rules">
        {rules.map(rule => (
          <li class="term-rule">
            <div class="term-rule-line">
              <span class="term-num">[{rule.num}]</span>
              <span class="term-rule-title">{rule.title}</span>
            </div>
            <div class="term-rule-desc">{rule.desc}</div>
          </li>
        ))}
      </ol>

      <div class="term-divider" aria-hidden="true"></div>

      <div class="term-closing" aria-hidden="true">
        <span class="term-output">&gt;&gt; Simple. Stable. Sustainable.</span>
      </div>

      <div class="term-prompt-line term-last" aria-hidden="true">
        <span class="term-ps1">admin@thequietblock</span><span class="term-sep">:</span><span class="term-cwd">~</span><span class="term-sep">$</span><span class="has-cursor"></span>
      </div>
    </div>
  </section>

  <script>
    import { initRulesTerminal } from '../scripts/rules-terminal';

    document.addEventListener('astro:page-load', () => {
      initRulesTerminal();
    });
  </script>
</BaseLayout>
